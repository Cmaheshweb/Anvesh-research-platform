// src/config/database.config.ts
import { TypeOrmModuleOptions } from '@nestjs/typeorm';
import * as dotenv from 'dotenv';
import { User } from '../user/user.entity'; // Import User entity

dotenv.config(); // Load environment variables from .env file

const databaseConfig: TypeOrmModuleOptions = {
  type: 'postgres',
  host: process.env.DATABASE_HOST || 'localhost',
  port: parseInt(process.env.DATABASE_PORT, 10) || 5432,
  username: process.env.DATABASE_USER || 'admin',
  password: process.env.DATABASE_PASSWORD || 'password',
  database: process.env.DATABASE_NAME || 'ai_research_db',
  entities: [User], // Add all your entity files here
  synchronize: false, // Keep 'false' in production, use migrations
  migrations: [__dirname + '/../database/migrations/*.ts'], // Path to migration files
  cli: {
    migrationsDir: 'src/database/migrations',
  },
  logging: true, // Set to 'true' to log SQL queries during development
};

export default databaseConfig;