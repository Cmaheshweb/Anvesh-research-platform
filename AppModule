// src/app.module.ts
import { Module } from '@nestjs/common';
import { AppController } from './app.controller';
import { AppService } from './app.service';
import { TypeOrmModule } from '@nestjs/typeorm';
import { ConfigModule } from '@nestjs/config'; // Import ConfigModule
import databaseConfig from './config/database.config'; // Import database configuration
import { AuthModule } from './auth/auth.module'; // Import AuthModule
import { User } from './user/user.entity'; // Import User Entity

@Module({
  imports: [
    ConfigModule.forRoot({ isGlobal: true }), // Load .env files globally
    TypeOrmModule.forRootAsync({ // Load database configuration asynchronously
      useFactory: () => ({
        ...databaseConfig,
        entities: [User], // Add all your entity files here
        migrations: [__dirname + '/database/migrations/*.ts'], // Path to migration files
        autoLoadEntities: true, // Automatically load entities (useful for development)
      }),
    }),
    AuthModule, // Add our Authentication module here
  ],
  controllers: [AppController],
  providers: [AppService],
})
export class AppModule {}